# PayOS Configuration
# Lấy từ https://my.payos.vn sau khi đăng ký tài khoản
PAYOS_CLIENT_ID=your_client_id_here
PAYOS_API_KEY=your_api_key_here
PAYOS_CHECKSUM_KEY=your_checksum_key_here

# Database Configuration (nếu cần)
DATABASE_URL=your_database_url_here

# App Configuration
SECRET_KEY=your_secret_key_here
BASE_URL=https://your-domain.com

# SMTP Configuration (for OTP emails)
# Nếu dùng Gmail: bật 2FA và tạo App Password tại https://myaccount.google.com/apppasswords
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your_email@gmail.com
SMTP_PASS=your_app_password

# Google OAuth (optional)
# Tạo OAuth Client ID tại https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# YouTube Cookies (QUAN TRỌNG - để bypass bot detection)
# Cách lấy cookies: Dùng extension "Get cookies.txt LOCALLY" trên Chrome/Firefox
# Sau đó encode base64: base64 -w 0 cookies.txt > cookies_b64.txt
# Set YOUTUBE_COOKIES = nội dung file cookies_b64.txt
YOUTUBE_COOKIES=

# YouTube PO Token (tùy chọn - tăng độ ổn định)
# Xem hướng dẫn: https://github.com/yt-dlp/yt-dlp/wiki/PO-Token-Guide
YOUTUBE_PO_TOKEN=
YOUTUBE_VISITOR_DATA=

# Proxy Configuration (CRITICAL - để bypass YouTube IP block)
# Nếu Railway bị YouTube chặn IP, BẮT BUỘC phải dùng proxy
# Format: http://username:password@proxy-host:port
# Hoặc: socks5://username:password@proxy-host:port
HTTP_PROXY=
HTTPS_PROXY=
SOCKS_PROXY=

# Gợi ý proxy providers:
# - Webshare.io: $2.99/GB, residential proxy
# - Bright Data: $500/tháng, enterprise
# - Smartproxy: $75/tháng, residential
# - ProxyMesh: $10/tháng, rotating proxy
